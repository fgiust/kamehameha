{
  "name": "kamehameha",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "build": "npm run build -w tenshindiff && npm run validate:data && vitest run && tsc -b && vite build && npm run generate:seo",
    "generate:seo": "node scripts/generate-seo.mjs",
    "validate:data": "node scripts/validate-genki-data.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/noto-sans-jp": "5.2.9",
    "@vercel/analytics": "2.0.1",
    "@vercel/kv": "3.0.0",
    "@vercel/speed-insights": "2.0.0",
    "i18next": "26.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "17.0.8",
    "react-router-dom": "7.15.1",
    "tenshindiff": "workspace:*",
    "wanakana": "5.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "25.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "google-translate-api-x": "10.7.2",
    "happy-dom": "17.4.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-checker": "0.13.0",
    "vitest": "2.1.9"
  }
}
